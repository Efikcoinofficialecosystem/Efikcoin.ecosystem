# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Your EFIK contract address (new deployment)
NEXT_PUBLIC_EFIK_CONTRACT_ADDRESS=0xYourNewContractAddress

# ThirdWeb client ID
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id

# Domain for auth (matches what you set in ThirdWeb)
NEXT_PUBLIC_AUTH_DOMAIN=efikcoin.ecosystem

# CoinGecko API for price data (optional)
NEXT_PUBLIC_COINGECKO_API_KEY=your_key
